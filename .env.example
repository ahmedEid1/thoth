# Database (matches docker-compose)
DATABASE_URL="postgresql://thoth:thoth_dev_pw@localhost:5433/thoth"
DIRECT_DATABASE_URL="postgresql://thoth:thoth_dev_pw@localhost:5433/thoth"

# Object store (MinIO locally; swap endpoint for prod S3 — console UI on :9011)
S3_ENDPOINT="http://localhost:9010"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="thoth"
S3_SECRET_ACCESS_KEY="thoth_dev_pw"
S3_BUCKET="thoth-corpus"
S3_FORCE_PATH_STYLE="true"

# Clerk — fill in from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Trigger.dev — fill in from https://cloud.trigger.dev
TRIGGER_PROJECT_REF="proj_..."
TRIGGER_SECRET_KEY="tr_dev_..."

# === LLM provider config ===
# Choose which provider lib/llm dispatches to. Default 'mistral' (free EU tier,
# reliable Zod-validated structured output across every node in Thoth's pipeline).
# Options: mistral | groq | gemini | anthropic | openai | claude-agent
LLM_PROVIDER="mistral"

# Optional one-shot fallback. When set, any thrown error from the primary
# provider's generateObject call (5xx, rate-limit, transient network) triggers
# a SINGLE retry against this provider before the error propagates. Pick a
# sibling free-tier provider for $0 resilience (e.g. groq when primary is
# mistral). Setting it equal to LLM_PROVIDER is a no-op. claude-agent is
# not a sensible fallback (CLI session, not an HTTP API).
LLM_FALLBACK_PROVIDER=""

# Mistral — default LLM + REQUIRED for PDF parsing (lib/pdf-parse.ts uses
# Mistral OCR API). Free Experiment tier at https://console.mistral.ai covers
# small-scale dev. Per-page pricing on paid tiers: $0.002/page standard,
# $0.001/page batch.
MISTRAL_API_KEY=""

# Groq — FREE TIER alternative. 30K tokens/min, 14400 req/day.
# Create at https://console.groq.com (~30s; GitHub login works).
GROQ_API_KEY=""

# Google Gemini — Free tier on Flash/Flash-Lite, but Vercel AI SDK has a
# known structured-output parse issue with Gemini Flash (vercel/ai#12187).
GOOGLE_GENERATIVE_AI_API_KEY=""

# Anthropic — PAID. Required only if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=""

# OpenAI — PAID. Required only if LLM_PROVIDER=openai.
OPENAI_API_KEY=""

# Claude Agent SDK (free with Claude Max subscription via Claude Code CLI auth)
# Use LLM_PROVIDER=claude-agent to route Thoth through Anthropic's Agent SDK,
# which inherits your local `claude` CLI session auth — no ANTHROPIC_API_KEY required.
# Prereq: Claude Code CLI installed + logged in (`claude login`).
# Best for: local-dev eval runs (free) when you have a Max subscription.
# NOT for: GitHub Actions / CI (no CLI auth in containers).

# Langfuse self-hosted (dev defaults — matches docker-compose LANGFUSE_INIT_* values)
LANGFUSE_PUBLIC_KEY="pk-lf-thoth-dev"
LANGFUSE_SECRET_KEY="sk-lf-thoth-dev-secret"
LANGFUSE_HOST="http://localhost:3030"

# === Optional operator knobs ===

# Per-run token ceiling (input + output across all RunSteps). Trips
# BudgetExceededError before the next runLLM call when exceeded. 250k covers
# a generous review; tune tighter in CI/eval or looser in production.
# MAX_TOKENS_PER_RUN="250000"

# Salt mixed into the SHA-256 of client IPs before they're used as keys in
# the in-memory demo rate limiter (lib/demo/rate-limit.ts). Override in
# production so hashes aren't predictable across deploys.
# IP_HASH_SALT="thoth-demo-static-salt"

# Operator panic button. Set to "1" to short-circuit /api/demo/start with a
# 503 demo_disabled response, BEFORE rate-limit + origin checks. Flip in the
# Vercel dashboard when a traffic spike threatens free-tier quotas; flip
# back when it subsides. No deploy needed.
# DEMO_DISABLED=""

# V2 outbound-search operator panic button. Set to "1" to refuse outbound
# discoverer fan-out from every run regardless of project.searchScope. Flip
# when an outbound provider misbehaves (Exa quota exhausted, OpenAlex
# 5xx-storm, ToS concern). Existing in-flight outbound runs see an error
# mid-run; new runs that need outbound coerce to uploaded_only.
# SEARCH_DISABLED=""

# Comma-separated email allow-list (case-insensitive) for /admin/* pages.
# Empty / unset means nobody — every /admin/* request 404s.
# ADMIN_EMAILS="ops@example.com,owner@example.com"

# Shared secret. When set, callers sending the same value in the
# `x-health-detail` header receive the raw DB error string in /api/health
# JSON. Unset (the common case) omits dbError unconditionally so Prisma
# error text (which routinely includes hostnames / ports / credentials)
# can't leak to public scrapers.
# HEALTH_DETAIL_TOKEN=""

# === Eval sweep knobs (`pnpm eval`) ===

# Comma-separated golden-id prefixes to run (the leading "NNN" before the
# first hyphen). Unset, empty, or "all" runs every golden in evals/golden/.
# The weekly eval CI cron uses a 6-golden smoke set via this env to fit
# the Mistral free-tier rate budget; workflow_dispatch can override.
# EVAL_GOLDENS="000,001,005"

# Per-golden walltime cap in milliseconds (default 15 min). A golden that
# exceeds this is logged + skipped; the sweep continues with the next
# golden. Tuned for the Mistral free-tier cite-check loop; bump if a paid
# provider needs longer or set lower to fail fast in CI.
# EVAL_GOLDEN_TIMEOUT_MS="900000"
