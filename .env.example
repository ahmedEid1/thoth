# Database (matches docker-compose)
DATABASE_URL="postgresql://atlas:atlas_dev_pw@localhost:5433/atlas"
DIRECT_DATABASE_URL="postgresql://atlas:atlas_dev_pw@localhost:5433/atlas"

# Object store (MinIO locally; swap endpoint for prod S3 — console UI on :9011)
S3_ENDPOINT="http://localhost:9010"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="atlas"
S3_SECRET_ACCESS_KEY="atlas_dev_pw"
S3_BUCKET="atlas-corpus"
S3_FORCE_PATH_STYLE="true"

# Clerk — fill in from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Trigger.dev — fill in from https://cloud.trigger.dev
TRIGGER_PROJECT_REF="proj_..."
TRIGGER_SECRET_KEY="tr_dev_..."

# === LLM provider config ===
# Choose which provider lib/llm dispatches to. Default 'gemini' (free).
# Options: gemini | anthropic | openai | groq
LLM_PROVIDER="gemini"

# Google Gemini — FREE TIER (default). 15 RPM, 1500 req/day.
# Create at https://aistudio.google.com (takes ~30 seconds).
GOOGLE_GENERATIVE_AI_API_KEY=""

# Anthropic — PAID. Required only if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=""

# OpenAI — PAID. Required only if LLM_PROVIDER=openai.
OPENAI_API_KEY=""

# Groq — FREE TIER. Required only if LLM_PROVIDER=groq.
# Create at https://console.groq.com.
GROQ_API_KEY=""

# Langfuse self-hosted (dev defaults — matches docker-compose LANGFUSE_INIT_* values)
LANGFUSE_PUBLIC_KEY="pk-lf-atlas-dev"
LANGFUSE_SECRET_KEY="sk-lf-atlas-dev-secret"
LANGFUSE_HOST="http://localhost:3030"
