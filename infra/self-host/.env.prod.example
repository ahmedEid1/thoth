# ============================================================================
# Thoth self-host production env — copy to .env.prod and fill in.
# ============================================================================
#
# WHAT MUST CHANGE before first boot:
#   - DOMAIN, ACME_EMAIL
#   - Every *_PASSWORD / *_SECRET / *_KEY value below (defaults are placeholders)
#   - CLERK_* and MISTRAL_API_KEY (these still come from cloud providers)
#
# WHAT'S SAFE TO LEAVE AS-IS:
#   - Internal service hostnames (postgres, minio, langfuse-web, etc.) — those
#     are docker-compose service names on the shared network.
#   - Bucket names (thoth-corpus, langfuse-events, langfuse-media)
#   - S3_REGION, S3_FORCE_PATH_STYLE (MinIO needs path-style)
#
# Generating secrets:
#   openssl rand -hex 32              # for LANGFUSE_ENCRYPTION_KEY (64 hex chars)
#   openssl rand -base64 32           # for passwords / NEXTAUTH_SECRET / SALT
# ============================================================================

# ── Domain & TLS ───────────────────────────────────────────────────────────
DOMAIN=your-domain.com
ACME_EMAIL=you@your-domain.com

# ── Thoth Postgres (replaces Neon) ─────────────────────────────────────────
# This must match the user/db in docker-compose.prod.yml (thoth/thoth).
POSTGRES_PASSWORD=CHANGE_ME_thoth_pg_password
DATABASE_URL=postgresql://thoth:CHANGE_ME_thoth_pg_password@postgres:5432/thoth
DIRECT_DATABASE_URL=postgresql://thoth:CHANGE_ME_thoth_pg_password@postgres:5432/thoth

# ── Thoth object store (MinIO, replaces Cloudflare R2) ─────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=thoth
S3_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret_key
S3_BUCKET=thoth-corpus
S3_FORCE_PATH_STYLE=true

# Public URL for presigned-URL generation (browsers need this to be reachable
# from the user's network). If you want clients to upload PDFs directly to
# MinIO you'll need to either:
#   (a) Add a `minio.{$DOMAIN}` route in Caddyfile and set this to the public URL.
#   (b) Stream uploads through the Thoth server (simpler — no extra TLS hop needed).
# Default (a) — uncomment and add the route in Caddyfile if you go that way:
# S3_PUBLIC_ENDPOINT=https://minio.your-domain.com

# ── Auth (Clerk Cloud — still hosted) ──────────────────────────────────────
# Clerk has a free 10K MAU tier. The day we want fully self-hosted auth, the
# follow-up is to swap to NextAuth + Postgres (separate refactor, not in M3.5c).
# Set the production allowed origin in Clerk dashboard to https://{$DOMAIN}.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME
CLERK_SECRET_KEY=sk_live_REPLACE_ME
CLERK_WEBHOOK_SIGNING_SECRET=whsec_REPLACE_ME

# ── Background jobs (Trigger.dev Cloud — still hosted) ─────────────────────
# Free 500K runs/mo. To self-host, see:
#   https://github.com/triggerdotdev/self-hosted-trigger.dev
# Then set TRIGGER_API_URL to your self-hosted base URL.
TRIGGER_PROJECT_REF=proj_REPLACE_ME
TRIGGER_SECRET_KEY=tr_prod_REPLACE_ME
# TRIGGER_API_URL=https://api.trigger.dev    # cloud default; override for self-host

# ── LLM provider ───────────────────────────────────────────────────────────
# Thoth supports 6 providers (mistral, groq, gemini, anthropic, openai, claude-agent).
# Self-host LLM on Oracle ARM free tier is not viable (no GPU), so all options
# below still talk to an external API. Mistral is the cheapest free path right now.
LLM_PROVIDER=mistral

# Mistral — free Experiment tier covers small-scale; paid is $0.002/page OCR
# and ~$0.40/1M input tokens. Sign up at https://console.mistral.ai.
# REQUIRED even if LLM_PROVIDER is something else, because PDF parsing (lib/pdf-parse.ts)
# uses Mistral OCR.
MISTRAL_API_KEY=REPLACE_ME

# Optional alternatives (uncomment + set if you switch LLM_PROVIDER):
# GROQ_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Tracing (self-hosted Langfuse) ─────────────────────────────────────────
# These match the LANGFUSE_INIT_* values in docker-compose.prod.yml so the
# project is bootstrapped on first boot with deterministic keys.
LANGFUSE_PUBLIC_KEY=pk-lf-thoth-prod
LANGFUSE_SECRET_KEY=CHANGE_ME_langfuse_secret_key
# Use the internal hostname for app → langfuse calls (no TLS hop needed):
LANGFUSE_HOST=http://langfuse-web:3000
# Or, if you'd rather the app talk to Langfuse over the public URL:
# LANGFUSE_HOST=https://langfuse.your-domain.com

# Langfuse infra secrets (only used inside docker-compose; not read by Thoth)
LANGFUSE_PG_PASSWORD=CHANGE_ME_langfuse_pg_password
LANGFUSE_MINIO_PASSWORD=CHANGE_ME_langfuse_minio_password
CLICKHOUSE_PASSWORD=CHANGE_ME_clickhouse_password
REDIS_PASSWORD=CHANGE_ME_redis_password
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
LANGFUSE_SALT=CHANGE_ME_openssl_rand_base64_32
# Must be exactly 64 hex chars (256-bit key). Generate with: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_openssl_rand_hex_32
LANGFUSE_INIT_USER_EMAIL=admin@your-domain.com
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_first_login_password

# ── Next.js / runtime ──────────────────────────────────────────────────────
NODE_ENV=production
# Thoth reads NEXT_PUBLIC_APP_URL for absolute callbacks (e.g., Clerk redirects).
NEXT_PUBLIC_APP_URL=https://your-domain.com
